{
  "name": "hospital-management-platform",
  "version": "1.0.0",
  "description": "Multi-tenant Hospital Management Platform",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/server.ts",
    "dev": "ts-node src/server.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:coverage": "jest --coverage",
    "seed:super-admin": "ts-node scripts/seed-super-admin.ts",
    "seed:tenants": "ts-node scripts/seed-tenants.ts",
    "seed:hospital-roles": "ts-node scripts/seed-hospital-roles.ts",
    "seed:patients": "ts-node scripts/seed-patients.ts",
    "seed:all": "npm run seed:super-admin && npm run seed:tenants && npm run seed:hospital-roles && npm run seed:patients"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.575.0",
    "@aws-sdk/s3-request-presigner": "3.575.0",
    "@types/multer": "^1.4.11",
    "bcrypt": "^6.0.0",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv-safe": "8.2.0",
    "express": "4.18.2",
    "express-rate-limit": "7.2.0",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "mongoose": "8.3.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "6.9.13",
    "pdfkit": "^0.18.0",
    "uuid": "9.0.1",
    "ws": "8.17.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "^25.7.0",
    "@types/nodemailer": "6.4.14",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "6.0.2",
    "@types/uuid": "9.0.8",
    "@types/ws": "8.5.10",
    "fast-check": "3.19.0",
    "jest": "29.7.0",
    "mongodb-memory-server": "9.1.1",
    "supertest": "7.0.0",
    "ts-jest": "29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
