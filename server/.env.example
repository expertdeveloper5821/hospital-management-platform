# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=

# JWT
JWT_SECRET=
JWT_EXPIRY=8h
INVITE_JWT_SECRET=
INVITE_JWT_EXPIRY=48h
RESET_TOKEN_EXPIRY=1h

# bcrypt
BCRYPT_ROUNDS=12

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# AWS S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
